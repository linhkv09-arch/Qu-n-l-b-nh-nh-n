# Sao chép file này thành ".env" và điền thông tin dự án Supabase của bạn.
# Lấy tại: Supabase Dashboard > Project Settings > API

# URL dự án Supabase (dạng https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Khóa "anon public" (KHÔNG phải service_role). Khóa này công khai được,
# dữ liệu được bảo vệ bằng đăng nhập (Auth) + RLS.
VITE_SUPABASE_ANON_KEY=your-anon-public-key
